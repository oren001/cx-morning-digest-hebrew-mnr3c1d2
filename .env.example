# Environment Variables Example
# Copy this file to .dev.vars for local development

# Cloudflare KV Namespace ID (required)
# Get this by running: wrangler kv:namespace create "DIGEST_STORAGE"
# Then copy the ID from the output
KV_NAMESPACE_ID=your_kv_namespace_id_here

# Optional: User ID for testing (defaults to 'default_user' if not set)
# In production, you'd implement proper authentication
TEST_USER_ID=test_user_123

# Optional: Scraping configuration
MAX_ARTICLES_PER_SCRAPE=50
SCRAPE_TIMEOUT_MS=30000

# Optional: ML scoring weights (defaults are set in code)
# WEIGHT_CLICKS=1.0
# WEIGHT_READ_TIME=0.5
# WEIGHT_RECENCY=0.3

# Optional: Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MINUTES=60